# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_SECRET_KEY=changeme      # used for JWT signing

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./dev.db
# For cloud: postgresql+asyncpg://user:pass@host/dbname

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── File Storage ─────────────────────────────────────────────────────────────
DATA_DIR=/Users/dana_khaing/party3d-data
# For cloud: set to an S3-compatible bucket path

# ── ML Pipeline ──────────────────────────────────────────────────────────────
OPENSPLAT_BIN=/Users/dana_khaing/OpenSplat/build/opensplat
MAX_GAUSSIANS=1000000
OPENSPLAT_ITERATIONS=30000
SAM2_CHECKPOINT=/Users/dana_khaing/models/sam2/sam2.1_hiera_base_plus.pt
PYTORCH_ENABLE_MPS_FALLBACK=1

# ── Processing limits ─────────────────────────────────────────────────────────
MAX_PHOTOS_PER_EVENT=400
JOB_TIMEOUT_SECONDS=7200    # 2 hours
MEMORY_ALERT_GB=18
MEMORY_KILL_GB=22
